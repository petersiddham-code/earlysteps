DATABASE_URL="postgresql://user:password@localhost:5432/earlysteps?schema=public"
PORT=3000
# Required in any real deployment — the dev-only fallback in auth.module.ts must never run
# in production. Generate with: openssl rand -base64 48
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# Media capture (issue #134). "local" writes per-family-encrypted blobs under
# MEDIA_STORAGE_DIR (relative to apps/backend, gitignored); "s3" is a stub until real
# bucket credentials exist.
STORAGE_DRIVER="local"
MEDIA_STORAGE_DIR="data/media"

# Optional. Without it, audio evidence (issue #140) is disabled and Assessment B simply
# gets no audio-derived evidence — same offline-first fallback as ANTHROPIC_API_KEY being
# unset disabling the free-text/results-summary LLM stages.
OPENAI_API_KEY=""
