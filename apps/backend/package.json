{
  "name": "@earlysteps/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "NestJS + Prisma API — intake -> scoring -> results pipeline (CLAUDE.md §3, §7).",
  "scripts": {
    "start:dev": "node --watch --loader ts-node/esm src/main.ts",
