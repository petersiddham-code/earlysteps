// Prisma schema mapping the data model in docs/product-plan.md §7.
//
// DomainProfileRecord.findings, RedFlagRecord.evidenceRefs, and similar fields are stored as
// JSONB rather than fully normalized child tables. That's a deliberate foundation-phase
// choice (CLAUDE.md: don't design for hypothetical future requirements) — normalize once
// real trend-graph/report query patterns are known, not before.
//
// The initial migration (prisma/migrations/20260702042258_init) was generated against a real
// local Postgres instance and is committed — `prisma migrate deploy` (or `migrate dev` for
// local development) applies it to any fresh database.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Login credentials (issue #94). Issue #23 added the one-to-one link to Family below —
/// still a standalone credentials table otherwise. `tier` exists so premium-tier gating
/// (the issue's stated motivation) has somewhere to read from later — nothing enforces it yet.
/// `role` (issue #125) gates the Admin Console; there's no self-service way to become an
/// admin — see prisma/promote-to-admin.ts.
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  /// bcrypt hash — the plaintext password is never stored or logged.
  passwordHash String
  tier         String   @default("free")
  role         String   @default("parent")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  family       Family?
  contentDrafts ContentDraft[]
}

/// Admin Console content-edit proposal (issue #127). Draft-only, by design: nothing ever
/// reads this table to serve live app content, and no code path writes packages/content
/// from it. Going live still requires a human to turn an approved draft into a real JSON
/// change via a normal PR + CI + docs/clinical-review sign-off (CLAUDE.md §9) — same gate
/// as a hand-edit today. See docs/clinical-review/2026-07-15-issue127-admin-content-editing-plan.md.
model ContentDraft {
  id            String    @id @default(cuid())
  /// One of shared-types' AdminEditableContentKey values, e.g. "questions.toddler".
  contentKey    String
  /// Dotted/bracketed address within that content key, e.g. "Q1.hint".
  fieldPath     String
  /// Live value captured at draft time, so the console can show a diff even if the live
  /// value later changes (e.g. from a merged PR) without needing to re-fetch history.
  currentValue  String
  proposedValue String
  /// Required rationale from the admin proposing the change.
  note          String
  createdById   String
  createdBy     User      @relation(fields: [createdById], references: [id])
  createdAt     DateTime  @default(now())
  status        String    @default("pending") // pending | discarded
  discardedAt   DateTime?

  @@index([contentKey, status])
}

model Family {
  id               String   @id @default(cuid())
  locale           String
  lowBandwidthMode Boolean  @default(false)
  /// Layered consent flags (data_storage / ai_analysis / media_capture / professional_sharing)
  /// — product plan §4.7. data_storage gates intake persistence (ScreeningService); the other
  /// three scopes are stored but not yet enforced anywhere — see docs/clinical-review/.
  consentFlags     Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  children         Child[]
  /// One family per account (issue #23), created lazily on first Consent Center visit —
  /// null for a guest session (never persisted at all) or a family created before this
  /// link existed. Logging in on a new device recovers this family via getFamilyByUserId
  /// instead of creating a duplicate. Also the multi-tenancy boundary: FamilyOwnershipGuard
  /// only restricts access once a family has an owner, so an unowned/guest family stays
  /// exactly as open as it is today.
  userId           String?  @unique
  user             User?    @relation(fields: [userId], references: [id])
  /// Per-family AES-256-GCM key (base64 of 32 random bytes) for media-at-rest encryption
  /// (issue #134, product plan §4.7 "media encrypted with per-family keys"). Generated
  /// lazily on the family's first media upload, never eagerly — a family that never
  /// records anything never gets a key. Deleting the family deletes the key with it,
  /// making any orphaned blob unreadable ciphertext.
  mediaEncryptionKey String?
  /// Parent-facing media retention window in days (issue #142, product plan §5 item 13).
  /// Shorter-only choice of 30/60/90 (MediaRetentionDays in shared-types), default 90
  /// matching the original fixed window. Changing it is retroactive — see
  /// FamiliesRepository.updateMediaRetentionDays, which recomputes retentionExpiresAt on
  /// every already-captured, non-retained MediaAssetRecord under the family.
  mediaRetentionDays Int      @default(90)
}

model Child {
  id         String   @id @default(cuid())
  familyId   String
  family     Family   @relation(fields: [familyId], references: [id])
  nickname   String
  /// Birth month (1–12) + year — deliberately month granularity, never the full date
  /// (data minimization, issue #25). The age band is DERIVED from these at read time
  /// (shared-types ageBand.ts), never stored, so it can't go stale as the child ages.
  birthMonth Int
  birthYear  Int
  /// Optional inclusive gender ('girl' | 'boy' | 'self_describe' | 'prefer_not_to_say').
  /// Stored only — any USE of it is gated clinical content (CLAUDE.md §9).
  gender       String?
  /// Caregiver's own words, only alongside gender = 'self_describe'.
  genderDetail String?
  languages  String[]
  createdAt  DateTime @default(now())

  intakeResponses     IntakeResponseRecord[]
  activityResults     ActivityResultRecord[]
  followUpSuggestions FollowUpSuggestionRecord[]
  domainProfiles   DomainProfileRecord[]
  supportEstimates SupportLevelEstimateRecord[]
  redFlags         RedFlagRecord[]
  supportPlans     SupportPlanRecord[]
  progressLogs     ProgressLogRecord[]
  mediaAssets      MediaAssetRecord[]
  reports          ReportRecord[]
  aiResultsSummary AiResultsSummaryRecord?

  @@index([familyId])
}

model IntakeResponseRecord {
  id         String   @id @default(cuid())
  childId    String
  child      Child    @relation(fields: [childId], references: [id])
  questionId String
  domain     String
  /// string | string[] | number — see @earlysteps/shared-types IntakeResponse['answer'].
  answer     Json
  timestamp  DateTime
  /// When the free-text response-analysis stage (issue #26) processed this row's typed
  /// text. Null = not yet analyzed (or contains no free text). Only set once the LLM call
  /// actually returned; scoring never depends on it.
  analyzedAt DateTime?

  /// Natural idempotency key (issue #33). The mobile client stamps a whole submission
  /// batch with one timestamp, so an exact replay (double-tap, network retry, offline
  /// sync re-delivery) carries identical (questionId, timestamp) pairs and is skipped via
  /// createMany({ skipDuplicates }). A genuine re-answer happens in a later submission and
  /// gets a fresh timestamp, so answer HISTORY is still retained (scoring reads only the
  /// latest per question — scoring-engine dedupeLatestByQuestion).
  @@unique([childId, questionId, timestamp])
  @@index([childId])
}

model ActivityResultRecord {
  id           String   @id @default(cuid())
  childId      String
  child        Child    @relation(fields: [childId], references: [id])
  activityId   String
  ageBand      String
  modality     String
  responseData Json
  timestamp    DateTime

  @@index([childId])
}

/// One recompute() snapshot. Never updated in place — a new row is inserted on every
/// recompute so history is retained for trend graphs and clinician reports (CLAUDE.md §7).
model DomainProfileRecord {
  id         String   @id @default(cuid())
  childId    String
  child      Child    @relation(fields: [childId], references: [id])
  computedAt DateTime
  /// The child's (derived) age band when this screening was computed — trend history must
  /// record which band each screening used, since the band itself is derived and a child
  /// ages between sessions (issue #25).
  ageBand    String
  /// DomainFinding[] — { domain, level, score, confidence, evidence_refs[] }.
  findings   Json

  @@index([childId, computedAt])
}

model SupportLevelEstimateRecord {
  id         String   @id @default(cuid())
  childId    String
  child      Child    @relation(fields: [childId], references: [id])
  level      String
  confidence String
  computedAt DateTime

  @@index([childId, computedAt])
}

model RedFlagRecord {
  id           String   @id @default(cuid())
  childId      String
  child        Child    @relation(fields: [childId], references: [id])
  type         String
  triggeredAt  DateTime
  evidenceRefs Json
  resolved     Boolean  @default(false)

  @@index([childId])
}

/// One LLM-proposed confirmation follow-up (issue #26). Created only under ai_analysis
/// consent, from a schema-validated signal in a caregiver's free-text answer. Purely a
/// suggestion: nothing here affects scoring — only the caregiver's structured answer to
/// the follow-up question (a normal IntakeResponseRecord) does.
model FollowUpSuggestionRecord {
  id               String    @id @default(cuid())
  childId          String
  child            Child     @relation(fields: [childId], references: [id])
  /// Follow-up question id in packages/content/follow-ups (FU_<red_flag_type>).
  followUpId       String
  redFlagType      String
  /// The intake question the free text was typed under.
  sourceQuestionId String
  /// The caregiver's own typed words, verbatim (free_text: prefix stripped).
  sourceQuote      String
  /// LLM-reported salience (low/medium/high) — advisory context only, never scored.
  salience         String
  status           String    @default("pending") // pending | answered
  createdAt        DateTime  @default(now())
  answeredAt       DateTime?

  @@index([childId, status])
}

model SupportPlanRecord {
  id             String   @id @default(cuid())
  childId        String
  child          Child    @relation(fields: [childId], references: [id])
  weekNumber     Int
  tasks          Json
  scripts        Json
  rewards        Json
  checklistState Json

  @@index([childId])
}

model ProgressLogRecord {
  id        String   @id @default(cuid())
  childId   String
  child     Child    @relation(fields: [childId], references: [id])
  metric    String
  value     Json
  timestamp DateTime
  note      String?

  @@index([childId])
}

/// Opt-in only (CLAUDE.md §2 rule 9) — a row must only be created alongside a fresh,
/// per-instance consent flag from the app layer (MediaService verifies media_capture
/// consent and mints consentId per upload; issue #134). The blob itself lives behind the
/// object-storage adapter under storageKey, encrypted with the family's key before it is
/// ever written. Mirrors @earlysteps/shared-types MediaAsset.
model MediaAssetRecord {
  id                 String    @id @default(cuid())
  childId            String
  child              Child     @relation(fields: [childId], references: [id])
  kind               String
  mimeType           String
  consentId          String
  storageKey         String
  capturedAt         DateTime
  retentionExpiresAt DateTime
  retainedByParent   Boolean   @default(false)
  /// Deletion-in-progress tombstone: set first, then blob delete, then row delete — a
  /// half-finished delete stays invisible to lists and is swept by the retention job.
  deletedAt          DateTime?
  /// Speech-to-text transcript, `audio` kind only (issue #140). Generated lazily on first
  /// use as Assessment B evidence and cached here permanently — never regenerated once set,
  /// since the underlying audio bytes for a given asset never change.
  transcript         String?
  transcribedAt      DateTime?

  @@index([childId])
}

model ReportRecord {
  id          String   @id @default(cuid())
  childId     String
  child       Child    @relation(fields: [childId], references: [id])
  generatedAt DateTime
  pdfUri      String
  sharedWith  String[]

  @@index([childId])
}

/// Cached independent AI results summary (issue #104). One row per child (unique childId) —
/// this is a narrative cache, not a scoring snapshot, so it's overwritten in place rather
/// than retaining history (contrast DomainProfileRecord, CLAUDE.md §7 only requires history
/// for the deterministic engine's own findings). contentHash is a hash of the answered
/// questions the narrative was generated from; a Results visit reuses this row unless the
/// hash no longer matches the child's current answers, avoiding a live LLM call every visit.
model AiResultsSummaryRecord {
  id          String   @id @default(cuid())
  childId     String   @unique
  child       Child    @relation(fields: [childId], references: [id])
  contentHash String
  /// AiResultsSummary shape minus generatedAt (stored separately below).
  content     Json
  generatedAt DateTime
}
