{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "paths": {
      "@earlysteps/shared-types": ["packages/shared-types/src/index.ts"],
      "@earlysteps/content": ["packages/content/src/index.ts"],
      "@earlysteps/scoring-engine": ["packages/scoring-engine/src/index.ts"],
      "@earlysteps/comparison-engine": ["packages/comparison-engine/src/index.ts"]
    }
  }
}
