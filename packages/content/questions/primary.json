  "questions": [
    {
      "id": "PR1",
      "domain": "communication",
      "age_band": "primary",
      "text": "How does [child] communicate day-to-day?",
      "type": "buttons",
      "options": [
        {
          "id": "full_conversations",
          "label": "Talks in full conversations"
        },
        {
          "id": "struggles_back_and_forth",
          "label": "Talks but struggles with back-and-forth"
        },
        {
          "id": "mostly_short_answers",
          "label": "Mostly short answers"
        },
        {
          "id": "limited_spoken",
          "label": "Limited spoken language"
        }
      ],
      "hint": "Pick what's most typical — everyone has quieter days."
    },
    {
      "id": "PR2",
      "domain": "communication",
      "age_band": "primary",
      "text": "Does [child] understand jokes, sarcasm, or figures of speech (like \"it's raining cats and dogs\")?",
      "type": "buttons",
      "options": [
        {
          "id": "yes_usually",
          "label": "Yes, usually"
        },
        {
          "id": "needs_it_explained",
          "label": "Sometimes, needs it explained"
        },
        {
          "id": "very_literal",
          "label": "Often takes things very literally"
        },
        {
          "id": "not_sure",
          "label": "Not sure"
        }
      ],
      "hint": "Taking things literally is a communication style, not a failing."
    },
    {
      "id": "PR3",
      "domain": "communication",
      "age_band": "primary",
      "text": "Can [child] retell a short story or explain what happened at school?",
      "type": "buttons",
      "options": [
        {
          "id": "yes_easily",
          "label": "Yes, easily"
        },
        {
          "id": "with_prompting",
          "label": "With some prompting"
        },
        {
          "id": "finds_it_hard",
          "label": "Finds this hard"
        },
        {
          "id": "not_sure",
          "label": "Not sure"
        }
      ],
      "hint": "Think of an ordinary day, not a special occasion."
    },
    {
      "id": "PR4",
      "domain": "social",
      "age_band": "primary",
      "text": "Does [child] have friends they regularly play or talk with?",
