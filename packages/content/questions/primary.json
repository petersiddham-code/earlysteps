      "options": [
        {
          "id": "close_friends",
          "label": "Yes, a few close friends"
        },
        {
          "id": "knows_people_few_close",
          "label": "Knows people but few close friendships"
        },
        {
          "id": "struggles_make_keep",
          "label": "Struggles to make/keep friends"
        },
        {
          "id": "not_sure",
          "label": "Not sure"
        }
      ],
      "hint": "One or two good friends counts just as much as a big group."
