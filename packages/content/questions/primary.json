      "options": [
        {
          "id": "good_back_and_forth",
          "label": "Good back-and-forth"
        },
        {
          "id": "own_topics",
          "label": "Mostly talks about their own interests"
        },
        {
          "id": "rarely_initiates",
          "label": "Rarely initiates conversation"
        },
        {
          "id": "not_sure",
          "label": "Not sure"
        }
      ],
      "hint": "Pick what happens most of the time."
    },
    {
      "id": "PR6",
      "domain": "social",
      "age_band": "primary",
      "text": "Does [child] pick up on how others are feeling without being told?",
