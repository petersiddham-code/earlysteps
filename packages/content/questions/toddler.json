      "text": "When you call [child]'s name from across the room, what usually happens?",
      "type": "dropdown",
      "options": [
        {
          "id": "looks_right_away",
          "label": "Looks or comes right away"
        },
        {
          "id": "after_few_tries",
          "label": "Looks after a few tries"
        },
        {
          "id": "doesnt_notice",
          "label": "Doesn't seem to notice"
        },
        {
          "id": "depends",
          "label": "Depends what they're doing"
        },
        {
          "id": "not_sure",
          "label": "Not sure"
        }
