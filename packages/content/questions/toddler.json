  "questions": [
    {
      "id": "T1",
      "domain": "communication",
      "age_band": "toddler",
      "text": "Roughly when did [child] first say a real word (not babbling)?",
      "type": "dropdown",
      "options": [
        {
          "id": "before_12mo",
          "label": "Before 12mo"
        },
        {
          "id": "12_18mo",
          "label": "12–18mo"
        },
        {
          "id": "18_24mo",
          "label": "18–24mo"
        },
        {
          "id": "after_2y",
          "label": "After 2 years"
        },
        {
          "id": "not_yet",
          "label": "Not yet"
        },
        {
          "id": "not_sure",
          "label": "Not sure"
        }
      ],
      "hint": "A rough guess is perfectly fine."
    },
    {
      "id": "T2",
      "domain": "communication",
      "age_band": "toddler",
      "text": "About how many words does [child] use now, even if not always clear?",
      "type": "dropdown",
      "options": [
        {
          "id": "none_yet",
          "label": "None yet"
        },
        {
          "id": "few_1_5",
          "label": "A few (1–5)"
        },
        {
          "id": "some_6_20",
          "label": "Some (6–20)"
        },
        {
          "id": "many_20_50",
          "label": "Many (20–50)"
        },
        {
          "id": "short_sentences",
          "label": "Short sentences (2+ words together)"
        }
      ],
      "hint": "Any way of counting is fine — you don't need to be exact."
    },
    {
      "id": "T3",
      "domain": "communication",
      "age_band": "toddler",
      "text": "Does [child] try to talk, point, or use gestures to tell you what they want?",
      "type": "buttons",
      "options": [
        {
          "id": "yes_often",
          "label": "Yes, often"
        },
        {
          "id": "sometimes",
          "label": "Sometimes"
        },
        {
          "id": "rarely",
          "label": "Rarely"
        },
        {
          "id": "not_sure",
          "label": "Not sure"
        }
      ],
      "hint": "Any way of communicating counts — words, sounds, pointing, or pulling you toward something."
    },
    {
