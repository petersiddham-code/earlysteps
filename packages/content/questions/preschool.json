{
  "version": "1.4.0",
  "locale": "en",
  "age_band": "preschool",
  "questions": [
    {
      "id": "P1",
      "domain": "communication",
      "age_band": "preschool",
      "text": "How does [child] usually talk?",
      "type": "dropdown",
      "options": [
        {
          "id": "full_sentences",
          "label": "Full sentences"
        },
        {
          "id": "short_phrases",
          "label": "Short phrases (2–3 words)"
        },
        {
          "id": "single_words",
          "label": "Single words"
        },
        {
          "id": "sounds_gestures",
          "label": "Mostly sounds/gestures"
        },
        {
          "id": "not_yet_talking",
          "label": "Not yet talking"
        }
      ],
      "hint": "Pick what's most typical for [child] day to day."
    },
    {
      "id": "P2",
      "domain": "communication",
      "age_band": "preschool",
      "text": "Can most people outside the family understand [child] when they talk?",
      "type": "buttons",
      "options": [
        {
          "id": "yes_easily",
          "label": "Yes, easily"
        },
        {
          "id": "with_effort",
          "label": "Sometimes, with effort"
        },
        {
          "id": "rarely",
          "label": "Rarely"
        },
        {
          "id": "not_sure",
          "label": "Not sure"
        }
      ],
      "hint": "Pick what feels closest."
    },
    {
      "id": "P3",
      "domain": "communication",
      "age_band": "preschool",
      "text": "Does [child] ask questions, like \"why\" or \"what's that\"?",
      "type": "buttons",
      "options": [
        {
          "id": "yes_often",
          "label": "Yes, often"
        },
        {
          "id": "sometimes",
          "label": "Sometimes"
        },
        {
          "id": "rarely",
          "label": "Rarely"
        },
        {
          "id": "not_sure",
          "label": "Not sure"
