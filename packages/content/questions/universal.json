{
  "version": "1.0.0",
  "locale": "en",
  "age_band": "universal",
  "questions": [
    {
      "id": "U1",
      "domain": "profile",
      "age_band": "universal",
      "text": "How old is [child]?",
      "type": "dropdown",
      "options": [],
      "hint": "You can update this anytime.",
      "allow_free_text": false
    },
    {
      "id": "U2",
      "domain": "profile",
      "age_band": "universal",
      "text": "What language(s) does your family mainly speak at home?",
      "type": "chip_multi_select",
      "options": [
        { "id": "english", "label": "English" },
        { "id": "spanish", "label": "Spanish" },
        { "id": "mandarin", "label": "Mandarin" },
        { "id": "hindi", "label": "Hindi" },
        { "id": "arabic", "label": "Arabic" },
        { "id": "french", "label": "French" },
        { "id": "other", "label": "Other — type it" }
      ],
      "hint": "Pick all that apply — it's okay if [child] hears more than one.",
      "allow_free_text": true
    },
    {
      "id": "U3",
      "domain": "profile",
      "age_band": "universal",
      "text": "Does [child] hear more than one language regularly (e.g., from grandparents, daycare)?",
      "type": "buttons",
      "options": [
        { "id": "yes", "label": "Yes" },
        { "id": "no", "label": "No" },
        { "id": "not_sure", "label": "Not sure" }
      ],
      "hint": "This just helps us understand their language environment — it's not a concern by itself."
    },
    {
      "id": "U4",
      "domain": "profile",
      "age_band": "universal",
      "text": "Was [child] born on their due date, early, or late?",
      "type": "dropdown",
      "options": [
        { "id": "on_time", "label": "On time" },
        { "id": "few_weeks_early", "label": "A few weeks early" },
        { "id": "very_early", "label": "Very early (before 32 weeks)" },
        { "id": "late", "label": "Late" },
        { "id": "not_sure", "label": "Not sure" }
      ],
      "hint": "Totally optional — skip if you don't know or would rather not say."
    },
    {
      "id": "U5",
      "domain": "profile",
      "age_band": "universal",
      "text": "Did [child] need any extra medical care right after birth (like a NICU stay)?",
      "type": "buttons",
      "options": [
        { "id": "yes", "label": "Yes" },
        { "id": "no", "label": "No" },
        { "id": "not_sure", "label": "Not sure" },
        { "id": "prefer_not_to_say", "label": "Prefer not to say" }
      ],
      "hint": "Totally optional — skip if you'd rather not say."
    },
    {
      "id": "U6",
      "domain": "profile",
      "age_band": "universal",
      "text": "Is there anyone else in the family — parents, siblings, cousins — with autism, ADHD, or a learning difference?",
      "type": "buttons",
      "options": [
        { "id": "yes", "label": "Yes" },
        { "id": "no", "label": "No" },
        { "id": "not_sure", "label": "Not sure" },
        { "id": "prefer_not_to_say", "label": "Prefer not to say" }
      ],
      "hint": "This helps us understand family patterns — it doesn't predict anything on its own."
    },
    {
      "id": "U7",
      "domain": "profile",
      "age_band": "universal",
      "text": "What made you want to check in today?",
      "type": "chip_multi_select",
      "options": [
        { "id": "noticed_myself", "label": "Something I noticed myself" },
        { "id": "teacher_carer", "label": "A teacher/carer mentioned something" },
        { "id": "doctor", "label": "A doctor suggested it" },
        { "id": "proactive", "label": "I'm just being proactive" },
        { "id": "family_member", "label": "A family member raised it" },
        { "id": "other", "label": "Other" }
      ],
      "hint": "There's no wrong answer — we just want to understand your starting point."
    },
    {
      "id": "U8",
      "domain": "profile",
      "age_band": "universal",
      "text": "On a scale of how worried you feel right now, where would you put yourself?",
      "type": "emoji_slider",
      "options": [
        { "id": "not_very_worried", "label": "😌 Not very worried" },
        { "id": "very_worried", "label": "😟 Very worried" }
      ],
      "hint": "However you're feeling is valid — this just helps us support you better."
    },
    {
      "id": "U9",
      "domain": "strengths",
      "age_band": "universal",
      "text": "What does [child] love doing most?",
      "type": "chip_multi_select",
      "options": [
        { "id": "music", "label": "Music" },
        { "id": "drawing_art", "label": "Drawing/art" },
        { "id": "building_blocks", "label": "Building/blocks" },
        { "id": "books", "label": "Books" },
        { "id": "screens_videos", "label": "Screens/videos" },
        { "id": "outdoor_play", "label": "Outdoor play" },
        { "id": "animals", "label": "Animals" },
        { "id": "numbers_letters", "label": "Numbers/letters" },
        { "id": "sports", "label": "Sports" },
        { "id": "other", "label": "Other — type it" }
      ],
      "hint": "This isn't a small question — we build the whole support plan around what [child] already enjoys.",
      "allow_free_text": true
    },
    {
      "id": "U10",
      "domain": "strengths",
      "age_band": "universal",
      "text": "What's something [child] is really good at?",
      "type": "chip_multi_select",
      "options": [
        { "id": "remembering_details", "label": "Remembering details" },
        { "id": "being_kind_gentle", "label": "Being kind/gentle" },
        { "id": "making_people_laugh", "label": "Making people laugh" },
        { "id": "focus_on_loved_things", "label": "Focus on things they love" },
        { "id": "physical_skills", "label": "Physical skills" },
        { "id": "other", "label": "Other" }
      ],
      "hint": "Brag a little — this matters as much as anything else in this form.",
      "allow_free_text": true
    }
  ]
}
